    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "mediabunny": "^1.46.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.3",
    "three": "^0.184.0",
    "vite": "^8.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "typescript": "~6.0.2",
    "vitest": "^4.1.8"
  }
}
