  "version": "0.2.0",
  "license": "MIT",
  "type": "module",
  "description": "High-end WebGL video edge refraction lab built with React, TypeScript, Three.js and GLSL.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
